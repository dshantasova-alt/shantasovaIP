CSS
* {
  box-sizing: border-box;
}
html, body {
  margin: 0;
  padding: 0;
  min-height: 100%;
  background-color: #000;
  color: #fff;
  font-family: "Antic Didone", serif;
}
body {
  overflow-x: hidden;
}
.site-header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 100;
  background-color: rgba(0,0,0,.85);
  border-bottom: 1px solid rgba(255,255,255,.15);
}
.header-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1rem 1.5rem;
}
.logo {
  font-family: "Meddon", cursive;
  font-size: 2rem;
  color: #fff;
  text-decoration: none;
  letter-spacing: .02em;
}
.site-nav {
  display: flex;
  gap: 2rem;
}
.site-nav a {
  color: #fff;
  text-decoration: none;
  font-size: 1.2rem;
  font-weight: 400;
  font-family: "Antic Didone", serif;
}
.favorite {
  font-size: 1.6rem;
  color: #fff;
  text-decoration: none;
}
.hero {
  min-height: 100vh;
  display: flex;
  align-items: flex-start;
  padding-top: 120px;
  background: linear-gradient(180deg, #000 0%, #000 60%, #111 100%);
}
.hero-content {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem 1.5rem 3rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
}
.hero-text {
  flex: 1 1 45%;
 margin-left: -150px;
}
.hero-media {
  flex: 1 1 45%;
  display: flex;
  justify-content: flex-end;
}
.hero-video {
  width: 300%;
  max-width: 620px;
  margin-top: -200px;
  margin-right: -200px;
  border-radius: 0;
  border: none;
  box-shadow: none;
  display: block;
}
.hero-title {
  margin: 0;
  font-family: "Antic Didone", serif;
  font-size: clamp(4rem, 12vw, 12rem);
  line-height: 1;
  letter-spacing: .04em;
  font-weight: 400;
}
.hero-subtitle {
  margin: .2rem 0 0;
  font-family: "Antic Didone", serif;
  font-size: clamp(2rem, 5vw, 4rem);
  line-height: 1.1;
  font-weight: 400;
}
.hero-small {
  margin-top: 1rem;
  font-family: "Meddon", cursive;
  font-size: clamp(1.5rem, 4vw, 2.5rem);
  line-height: 1.2;
  color: #fff;
}
.site-footer {
  width: 100%;
  padding: 0;
  border-top: none;
  display: block;
  background-color: #000;
}
.site-footer .footer-image {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
}
.particle {
  position: fixed;
  pointer-events: none;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(255,182,193,1), rgba(255,105,180,0.85));
  filter: drop-shadow(0 0 8px rgba(255,105,180,0.7));
  transform-origin: center;
  will-change: transform, opacity;
  animation: particleSpin 2s ease-out infinite;
}

@keyframes particleSpin {
  from { transform: translate(0, 0) rotate(0deg) scale(1); opacity: 1; }
  to { transform: translate(var(--dx), var(--dy)) rotate(360deg) scale(0.25); opacity: 0.4; }
}

@media (max-width: 1200px) {
  .hero-content {
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
  }
  .hero-text,
  .hero-media {
    flex: 1 1 100%;
    max-width: 100%;
    justify-content: center;
    text-align: center;
  }
  .hero-text {
    margin-top: 1rem;
  }
  .hero-video {
    max-width: 100%;
  }
}

@media (max-width: 768px) {
  .hero {
    padding-top: 80px;
  }
  .hero-title {
    font-size: clamp(3rem, 10vw, 8rem);
  }
  .hero-subtitle {
    font-size: clamp(1.7rem, 6vw, 2.6rem);
  }
  .hero-small {
    font-size: clamp(1.3rem, 5vw, 2rem);
  }
  .header-inner {
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
  .site-nav {
    gap: 1rem;
    font-size: 1rem;
  }
}
