const quotes = [
  'Flowers bloom softly, as if they remember how to hope.',
  'A flower does not rush, yet it becomes everything it needs to be.',
  'In every petal, there is a quiet kind of courage.',
  'Flowers grow through dirt and still choose beauty.',
  'A blooming flower is the earth smiling in color.',
  'Even the smallest flower carries a universe of grace.',
  'Flowers speak in colors when words are not enough.',
  'A single flower can turn an ordinary moment into something gentle.',
  'Flowers remind us that growth can be quiet and still powerful.',
  'Petals fall, but the memory of their beauty lingers.',
  'A flower blooms not for attention, but because it must.',
  'There is something brave about a flower opening to the world.',
  'Flowers hold sunlight in the softness of their petals.',
  'Where flowers grow, something in the soul feels lighter.',
  'A field of flowers is a reminder that life can be soft and wild at once.'
];

const quoteModal = document.getElementById('quoteModal');
const openQuoteModal = document.getElementById('openQuoteModal');
const closeQuoteModal = document.getElementById('closeQuoteModal');
const generateQuote = document.getElementById('generateQuote');
const quoteText = document.getElementById('quoteText');

function openModal() {
  quoteModal.classList.remove('hidden');
}

function closeModal() {
  quoteModal.classList.add('hidden');
}

function getRandomQuote() {
  const randomIndex = Math.floor(Math.random() * quotes.length);
  return quotes[randomIndex];
}

openQuoteModal.addEventListener('click', openModal);
closeQuoteModal.addEventListener('click', closeModal);
quoteModal.addEventListener('click', (event) => {
  if (event.target === quoteModal) {
    closeModal();
  }
});
generateQuote.addEventListener('click', () => {
  quoteText.textContent = getRandomQuote();
});

